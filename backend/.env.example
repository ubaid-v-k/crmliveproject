# Production .env Template
# Use this as a guide to set environment variables on your deployment platform (Railway, Render, etc.)

# Django Settings
DEBUG=False
SECRET_KEY="generate-a-random-secret-key-for-production"
ALLOWED_HOSTS="your-backend-domain.com,localhost"

# Database Configuration
DB_NAME=crm_db
DB_USER=postgres
DB_PASSWORD=your-complex-password
DB_HOST=your-db-host.railway.app
DB_PORT=5432
CONN_MAX_AGE=60

# CORS Settings
CORS_ALLOWED_ORIGINS="https://your-frontend-domain.vercel.app,http://localhost:3000,http://127.0.0.1:3000"

# Email Configuration (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER="your-email@gmail.com"
EMAIL_HOST_PASSWORD="your-app-specific-password"

# Logging
DJANGO_LOG_LEVEL=INFO
